# 数据文件（不提交到Git）
data/raw/*

# 存档数据（按期号命名，手动提交）
!data/archived/
!data/archived/*.csv
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/cache/*
!data/cache/.gitkeep
data/*.csv

# 输出目录（保留目录结构+预测JSON）
output/*
!output/*/
!output/**/.gitkeep
!output/predictions/*.json
!output/predictions/latest_*.json

logs/*
!logs/.gitkeep

# Python缓存
__pycache__/
*.pyc
*.pyo

# 环境
venv/
.env
